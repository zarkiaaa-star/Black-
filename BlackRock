<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم الاحترافية</title>
    <style>
        /* تصميم الواجهة - CSS */
        body {
            background-color: #0f172a; /* لون داكن احترافي */
            color: #f8fafc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 500px;
            margin: auto;
            background: #1e293b;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            border: 1px solid #334155;
        }
        h2 { text-align: center; color: #38bdf8; }
        .balance-card {
            background: linear-gradient(135deg, #0ea5e9, #2563eb);
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            margin-bottom: 20px;
        }
        .btn-action {
            width: 100%;
            padding: 12px;
            background-color: #38bdf8;
            border: none;
            border-radius: 8px;
            color: #0f172a;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-action:hover { background-color: #7dd3fc; }
        .input-group { margin-bottom: 15px; }
        input {
            width: 90%;
            padding: 10px;
            border-radius: 5px;
            border: 1px solid #334155;
            background: #0f172a;
            color: white;
        }
    </style>
</head>
<body>

    <div class="container">
        <h2>لوحة المستثمر الذكي</h2>
        
        <div class="balance-card">
            <p>الرصيد الحالي</p>
            <h1 id="balance">0.00 $</h1>
        </div>

        <div class="input-group">
            <label>أدخل مبلغ الإيداع:</label><br><br>
            <input type="number" id="amount" placeholder="0.00">
        </div>

        <button class="btn-action" onclick="updateBalance()">إضافة رصيد الآن</button>
        
        <p style="font-size: 12px; color: #94a3b8; text-align: center; margin-top: 20px;">
            تم التشفير بواسطة نظام الحماية المتقدم
        </p>
    </div>

    <script>
        // الأوامر البرمجية - JavaScript
        function updateBalance() {
            let amount = document.getElementById('amount').value;
            let currentBalance = document.getElementById('balance');
            
            if(amount > 0) {
                currentBalance.innerText = amount + " $";
                alert("تم تحديث الرصيد بنجاح!");
            } else {
                alert("يرجى إدخال مبلغ صحيح");
            }
        }
    </script>
</body>
</html>
